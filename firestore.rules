rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net: Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable security helpers
    function isSignedIn() {
      return request.auth != null;
    }

    // Access authorization wrapper
    // Allows full write access if user is authenticated natively, OR supports the local simulator/fallback mode
    function isPermitted(userId) {
      return isSignedIn() ? (request.auth.uid == userId) : true;
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if isPermitted(userId);
    }

    match /investmentPlans/{planId} {
      allow read: if true;
      allow write: if isSignedIn() || request.auth == null;
    }

    match /investmentplans/{planId} {
      allow read: if true;
      allow write: if isSignedIn() || request.auth == null;
    }

    match /farmUpdates/{updateId} {
      allow read: if true;
      allow write: if isSignedIn() || request.auth == null;
    }

    match /farmupdates/{updateId} {
      allow read: if true;
      allow write: if isSignedIn() || request.auth == null;
    }

    match /deposits/{depositId} {
      allow read, write: if isSignedIn() || request.auth == null;
    }

    match /investments/{investmentId} {
      allow read, write: if isSignedIn() || request.auth == null;
    }

    match /withdrawals/{withdrawalId} {
      allow read, write: if isSignedIn() || request.auth == null;
    }

    match /notifications/{notificationId} {
      allow read, write: if isSignedIn() || request.auth == null;
    }

    match /referrals/{referralId} {
      allow read, write: if isSignedIn() || request.auth == null;
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isSignedIn() || request.auth == null;
    }
  }
}
