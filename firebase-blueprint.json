{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "The custom metadata and wallet balance for each registered investor or admin",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "password": { "type": "string" },
        "name": { "type": "string" },
        "fullname": { "type": "string" },
        "balance": { "type": "number" },
        "walletBalance": { "type": "number" },
        "totalInvested": { "type": "number" },
        "totalEarnings": { "type": "number" },
        "referralBonus": { "type": "number" },
        "totalProfit": { "type": "number" },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "registeredAt": { "type": "string" },
        "createdAt": { "type": "string" },
        "isBanned": { "type": "boolean" }
      },
      "required": ["id", "email", "name"]
    },
    "investmentPlans": {
      "title": "Investment Plan",
      "description": "An agriculture investment plan offered by FarmRise (e.g., Chicken, Pig batches)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "minAmount": { "type": "number" },
        "maxAmount": { "type": "number" },
        "profitPercent": { "type": "number" },
        "durationDays": { "type": "number" },
        "imageUrl": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "dailyProfit": { "type": "number" },
        "totalReturn": { "type": "number" }
      },
      "required": ["id", "name", "type", "minAmount", "maxAmount"]
    },
    "farmUpdates": {
      "title": "Farm Update",
      "description": "Real-time updates published by the farm administrators on livestock health, biotech, or feed integrations",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "type": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "title", "content"]
    },
    "deposits": {
      "title": "Deposit",
      "description": "Wallet deposit requests submitted by investors for review, with transaction reference or receipt image proof",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string" },
        "transactionId": { "type": "string" },
        "proofImageUrl": { "type": "string" },
        "imageUrl": { "type": "string" },
        "rejectionReason": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "userId", "amount", "status"]
    },
    "investments": {
      "title": "Investment",
      "description": "An active or completed agricultural investment initiated by an investor in a specific plan",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "planId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "dailyPayout": { "type": "number" },
        "nextPayoutAt": { "type": "string" },
        "durationDays": { "type": "number" },
        "daysElapsed": { "type": "number" },
        "totalPaid": { "type": "number" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "userId", "planId", "amount", "status"]
    },
    "withdrawals": {
      "title": "Withdrawal",
      "description": "Cash payout requests representing redeemed crop yields or available referral earnings to bank",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "accountDetails": { "type": "string" },
        "status": { "type": "string" },
        "rejectionReason": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "userId", "amount", "accountDetails", "status"]
    },
    "notifications": {
      "title": "Notification",
      "description": "User specific notifications about deposit updates, crop yields, payouts, or broadcasts",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "userId", "title", "message"]
    },
    "referrals": {
      "title": "Referral Link",
      "description": "Referral registry mapping one investor user account to another and documenting bonuses",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "referrerId": { "type": "string" },
        "referredId": { "type": "string" },
        "referredEmail": { "type": "string" },
        "status": { "type": "string" },
        "bonusPaid": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "referrerId"]
    },
    "categories": {
      "title": "Livestock Category",
      "description": "Featured livestock sectors with pictures, descriptions, and metadata",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "imageUrl": { "type": "string" },
        "description": { "type": "string" },
        "emoji": { "type": "string" }
      },
      "required": ["id", "name", "type", "imageUrl", "description", "emoji"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "users",
      "description": "Active developer & investor profile accounts"
    },
    "investmentPlans/{planId}": {
      "schema": "investmentPlans",
      "description": "Poultry & Piggery product plans"
    },
    "farmUpdates/{updateId}": {
      "schema": "farmUpdates",
      "description": "Chronological bioupdates from farm feeds"
    },
    "deposits/{depositId}": {
      "schema": "deposits",
      "description": "Incoming cash investment deposit actions"
    },
    "investments/{investmentId}": {
      "schema": "investments",
      "description": "Active crop breeding investments"
    },
    "withdrawals/{withdrawalId}": {
      "schema": "withdrawals",
      "description": "Outgoing yield crops bank payouts"
    },
    "notifications/{notificationId}": {
      "schema": "notifications",
      "description": "Read / Unread push logs"
    },
    "referrals/{referralId}": {
      "schema": "referrals",
      "description": "User invite connections"
    },
    "categories/{categoryId}": {
      "schema": "categories",
      "description": "Customizable livestock sector categories"
    }
  }
}
