# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# SUPABASE: Configuration variables for Supabase Database and Auth.
# Leave blank to run the app in Local Sandbox fallback mode automatically!
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# APPWRITE: Configuration variables for Appwrite Database and Auth.
# Leave blank to run the app in Local Sandbox fallback mode automatically!
VITE_APPWRITE_ENDPOINT="https://cloud.appwrite.io/v1"
VITE_APPWRITE_PROJECT_ID=""
VITE_APPWRITE_DATABASE_ID=""
VITE_APPWRITE_USERS_COLLECTION_ID=""
VITE_APPWRITE_PLANS_COLLECTION_ID=""
VITE_APPWRITE_DEPOSITS_COLLECTION_ID=""
VITE_APPWRITE_INVESTMENTS_COLLECTION_ID=""
VITE_APPWRITE_WITHDRAWALS_COLLECTION_ID=""
VITE_APPWRITE_NOTIFICATIONS_COLLECTION_ID=""
VITE_APPWRITE_FARM_UPDATES_COLLECTION_ID=""
VITE_APPWRITE_REFERRALS_COLLECTION_ID=""
